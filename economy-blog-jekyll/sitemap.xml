---
layout: null
permalink: /sitemap.xml
---
<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
  {% assign pages = site.pages | concat: site.posts %}
  {% for p in pages %}
    {% unless p.sitemap == false or p.url contains '/assets/' %}
  <url>
    <loc>{{ p.url | replace:'index.html','' | absolute_url }}</loc>
    <lastmod>{% if p.date %}{{ p.date | date_to_xmlschema }}{% else %}{{ site.time | date_to_xmlschema }}{% endif %}</lastmod>
  </url>
    {% endunless %}
  {% endfor %}
</urlset>
