PORT=4000
REDIS_URL=redis://localhost:6379
OUTPUT_DIR=./outputs

# Agent bridge mode: mock | webhook | openclaw-cli
AGENT_BRIDGE_MODE=openclaw-cli

# Webhook mode only
# AGENT_BRIDGE_WEBHOOK_URL=http://localhost:8787/agent/generate
# AGENT_BRIDGE_BEARER_TOKEN=

# openclaw-cli mode only
OPENCLAW_BIN=openclaw
OPENCLAW_AGENT_SESSION_ID=p2a-worker
OPENCLAW_AGENT_TIMEOUT_SECONDS=120
